                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('oCloudId', jsonData.oCloudId);",
                  "    console.log('OCloud ID saved: ' + jsonData.oCloudId);",
                  "}"
