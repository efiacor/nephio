    {
      "name": "3. FocomProvisioningRequest Workflow",
      "item": [
        {
          "name": "3.1 Create FPR Draft",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('fprId', jsonData.provisioningRequestId);",
                  "    console.log('FPR ID saved: ' + jsonData.provisioningRequestId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"edge-cluster-deployment-01\",\n  \"description\": \"Edge cluster deployment for site A\",\n  \"oCloudId\": \"{{oCloudId}}\",\n  \"templateName\": \"edge-cluster-template\",\n  \"templateVersion\": \"v1.0.0\",\n  \"templateParameters\": {\n    \"cpu\": \"4\",\n    \"memory\": \"8Gi\",\n    \"replicas\": 3,\n    \"storage\": \"100Gi\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/draft",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "draft"]
            }
          }
        },
        {
          "name": "3.2 Get FPR Draft",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}/draft",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}", "draft"]
            }
          }
        },
        {
          "name": "3.3 Update FPR Draft",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated edge cluster deployment for site A\",\n  \"templateParameters\": {\n    \"cpu\": \"8\",\n    \"memory\": \"16Gi\",\n    \"replicas\": 5,\n    \"storage\": \"200Gi\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}/draft",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}", "draft"]
            }
          }
        },
        {
          "name": "3.4 Validate FPR Draft",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}/draft/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}", "draft", "validate"]
            },
            "description": "Validates the FPR draft including schema validation of templateParameters against the referenced TemplateInfo's templateParameterSchema. Returns structured schema validation errors if parameters do not conform."
          },
          "response": [
            {
              "name": "Validation Passed",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}/draft/validate",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}", "draft", "validate"]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"validationResult\": {\n    \"success\": true,\n    \"validationTime\": \"2026-03-26T10:00:00Z\"\n  },\n  \"draft\": {\n    \"name\": \"edge-cluster-deployment-01\",\n    \"description\": \"Edge cluster deployment for site A\",\n    \"templateName\": \"edge-cluster-template\",\n    \"templateVersion\": \"v1.0.0\",\n    \"templateParameters\": {\n      \"cpu\": \"4\",\n      \"memory\": \"8Gi\",\n      \"replicas\": 3,\n      \"storage\": \"100Gi\"\n    }\n  }\n}"
            },
            {
              "name": "Validation Failed - Schema Errors",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}/draft/validate",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}", "draft", "validate"]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"validationResult\": {\n    \"success\": false,\n    \"validationTime\": \"2026-03-26T10:00:00Z\",\n    \"errors\": [\n      \"Template parameter 'replicas' violates constraint 'type': Invalid type. Expected: integer, given: string\",\n      \"Template parameter '(root)' violates constraint 'required': cpu is required\"\n    ],\n    \"schemaErrors\": [\n      {\n        \"field\": \"replicas\",\n        \"description\": \"Invalid type. Expected: integer, given: string\",\n        \"constraint\": \"type\"\n      },\n      {\n        \"field\": \"(root)\",\n        \"description\": \"cpu is required\",\n        \"constraint\": \"required\"\n      }\n    ]\n  },\n  \"draft\": {\n    \"name\": \"edge-cluster-deployment-01\",\n    \"description\": \"Edge cluster deployment for site A\",\n    \"templateName\": \"edge-cluster-template\",\n    \"templateVersion\": \"v1.0.0\",\n    \"templateParameters\": {\n      \"replicas\": \"not-a-number\",\n      \"memory\": \"8Gi\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "3.4b Create FPR Draft - Invalid Parameters",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"invalid-params-fpr\",\n  \"description\": \"FPR with invalid templateParameters for schema validation demo\",\n  \"oCloudId\": \"{{oCloudId}}\",\n  \"templateName\": \"edge-cluster-template\",\n  \"templateVersion\": \"v1.0.0\",\n  \"templateParameters\": {\n    \"replicas\": \"not-a-number\",\n    \"memory\": \"8Gi\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/draft",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "draft"]
            },
            "description": "Step 1: Creates an FPR draft with intentionally invalid templateParameters. The 'replicas' field is a string instead of integer, and the required 'cpu' field is missing. This will succeed with 201 (drafts are not schema-validated on creation unless FOCOM_EARLY_SCHEMA_VALIDATION=true). Run step 3.4c next to see the schema validation errors."
          }
        },
        {
          "name": "3.4c Validate FPR Draft - Invalid Parameters (Shows Errors)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/invalid-params-fpr/draft/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "invalid-params-fpr", "draft", "validate"]
            },
            "description": "Step 2: Validates the invalid FPR draft created in step 3.4b. This will return structured schema validation errors showing that 'replicas' has wrong type (string instead of integer) and 'cpu' is missing (required field)."
          },
          "response": [
            {
              "name": "Validation Failed - Schema Errors",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/invalid-params-fpr/draft/validate",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "focom-provisioning-requests", "invalid-params-fpr", "draft", "validate"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": {\n    \"code\": \"VALIDATION_ERROR\",\n    \"message\": \"Template parameters validation failed\",\n    \"details\": \"Template parameter 'replicas' violates constraint 'invalid_type': Invalid type. Expected: integer, given: string\"\n  }\n}"
            }
          ]
        },
        {
          "name": "3.5 Approve FPR Draft",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}/draft/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}", "draft", "approve"]
            }
          }
        },
        {
          "name": "3.6 Get FPR (Approved)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests/{{fprId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests", "{{fprId}}"]
            }
          }
        },
        {
          "name": "3.7 List All FPRs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/focom-provisioning-requests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "focom-provisioning-requests"]
            }
          }
        }
      ]
    }
