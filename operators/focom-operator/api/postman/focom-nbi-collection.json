            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"demo-ocloud-01\",\n  \"description\": \"Demo OCloud for testing\",\n  \"o2imsSecret\": {\n    \"secretRef\": {\n      \"name\": \"o2ims-credentials\",\n      \"namespace\": \"focom-system\"\n    }\n  }\n}"
